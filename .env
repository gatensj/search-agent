# --- Anthropic API ---
# Get a key at https://platform.claude.com  (set a monthly spend limit in the console!)
ANTHROPIC_API_KEY=sk-ant-...

# --- Agent tuning (optional; these are the defaults) ---
AGENT_MODEL=sonnet
AGENT_MAX_TURNS=25
AGENT_MAX_BUDGET_USD=0.50

# --- Telegram (Phase 2) ---
# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=
# Send /start to your bot; it replies with this number
TELEGRAM_ALLOWED_CHAT_ID=
